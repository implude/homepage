---
import CodeQuality from '../components/CodeQuality.svelte';
import Hero from '../components/Hero.svelte';
import Members from '../components/Members.svelte';
import Philosophy from '../components/Philosophy.svelte';
import Stack from '../components/Stack.svelte';
import Base from '../layouts/Base.astro';
import type { Generation } from '../types/members.ts';

const MEMBERS_API = import.meta.env.MEMBERS_API_URL || 'http://localhost:3000';

let generations: Generation[] = [];

try {
	const res = await fetch(`${MEMBERS_API}/members`);
	generations = await res.json();
} catch (e) {
	console.error('Failed to fetch members:', e);
}
---

<Base
	title="임플루드 (IMPLUDE) | Right Tool, Right Time"
	description="임플루드(IMPLUDE) 공식 홈페이지. Right Tool, Right Time 철학으로 코드 퀄리티를 추구하고 실제 서비스까지 배포하는 프로그래밍 동아리입니다.">
	<Hero client:load />
	<Philosophy client:visible />
	<Stack client:visible />
	<CodeQuality client:visible />
	{generations.length > 0 && <Members client:visible {generations} />}
</Base>

<style lang="scss">
	@use '../styles/variables' as *;

	.section {
		min-height: 100vh;
		padding-top: $space-24;
	}
</style>
