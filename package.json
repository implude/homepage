		"@fontsource/pretendard": "^5.2.5",
		"@iconify/svelte": "^5.2.1",
		"@studio-freight/lenis": "^1.0.42",
		"@threlte/core": "^8.4.1",
		"@threlte/extras": "^9.8.1",
		"@types/three": "^0.183.1",
		"astro": "^5.18.0",
		"gsap": "^3.14.2",
		"open-props": "^1.7.23",
